# ==============================================================
# RoadVisionAI — environment template
# Copy to .env and fill secrets. NEVER commit .env (see .gitignore)
# ==============================================================

# --- Application ---
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# --- Security (generate: openssl rand -hex 32) ---
JWT_SECRET_KEY=change-me-32-chars-minimum-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL 17 + PostGIS (schema v4.2) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=roadvision
POSTGRES_PASSWORD=change-me
POSTGRES_DB=roadvisionai

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=roadvision
MINIO_SECRET_KEY=change-me
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=localhost:9000

# --- ChromaDB ---
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# --- Gemini 2.5 Pro (CDC: temperature 0.2) ---
GEMINI_API_KEY=

# --- CORS (Angular dev server) ---
CORS_ORIGINS=["http://localhost:4200"]
